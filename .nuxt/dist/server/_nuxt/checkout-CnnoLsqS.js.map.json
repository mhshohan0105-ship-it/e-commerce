{"file":"checkout-CnnoLsqS.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;AAiHA,UAAM,YAAY,aAAY;AAG9B,UAAM,YAAY,SAAS,MAAM;AAC/B,aAAO,UAAU,MAAM,SAAS,IAAI,UAAU,QAAQ;AAAA,QACpD,EAAE,IAAI,GAAG,MAAM,0BAA0B,UAAU,kBAAmB,OAAO,IAAO,UAAU,EAAC;AAAA,QAC/F,EAAE,IAAI,GAAG,MAAM,mBAAmB,UAAU,SAAS,OAAO,IAAO,UAAU,EAAC;AAAA,MAClF;AAAA,IACA,CAAC;AAED,UAAM,YAAY,SAAS,MAAM;AAC/B,aAAO,UAAU,MAAM,OAAO,CAAC,OAAO,SAAS,QAAS,KAAK,QAAQ,KAAK,UAAW,CAAC;AAAA,IACxF,CAAC;;;AA5HM,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,2CAAuC,MAAA,CAAA,CAAA,6yEAAA;;QA+ChC,MAAK;AAAA,QAAqB,OAAM;AAAA;;AAkBpBC,oBAAA,UAAA,QAAR,SAAI;iQAGmHC,eAAA,KAAK,QAAQ,+GAIvGA,eAAA,KAAK,IAAI,0CACRA,eAAA,KAAK,QAAQ,iDAEZA,gBAAA,KAAK,QAAQ,KAAK,UAAU,QAAO,CAAA,CAAA;;uLAQ9CA,eAAA,UAAA,MAAU,QAAO,CAAA,CAAA,uRAQhBA,gBAAA,UAAA,cAAkB,QAAO,CAAA,CAAA,mOAOYA,gBAAA,UAAA,cAAkB,QAAO,CAAA,CAAA;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../pages/checkout.vue"],"sourcesContent":["<template>\n  <div class=\"container mx-auto px-4 py-8 max-w-6xl\">\n    <h1 class=\"text-3xl font-bold mb-8\">Checkout</h1>\n    \n    <div class=\"flex flex-col lg:flex-row gap-12\">\n      <!-- Checkout Form -->\n      <div class=\"lg:w-2/3\">\n        <!-- Contact Info -->\n        <section class=\"mb-10\">\n          <h2 class=\"text-xl font-bold mb-4\">Contact Information</h2>\n          <div class=\"grid gap-4\">\n            <input type=\"email\" placeholder=\"Email Address\" class=\"w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            <label class=\"flex items-center gap-2 text-sm text-gray-600\">\n              <input type=\"checkbox\" class=\"rounded text-blue-600\">\n              Email me with news and offers\n            </label>\n          </div>\n        </section>\n\n        <!-- Shipping Address -->\n        <section class=\"mb-10\">\n          <h2 class=\"text-xl font-bold mb-4\">Shipping Address</h2>\n          <div class=\"grid grid-cols-2 gap-4\">\n            <input type=\"text\" placeholder=\"First Name\" class=\"col-span-1 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            <input type=\"text\" placeholder=\"Last Name\" class=\"col-span-1 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            <input type=\"text\" placeholder=\"Company (optional)\" class=\"col-span-2 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            <input type=\"text\" placeholder=\"Address\" class=\"col-span-2 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            <input type=\"text\" placeholder=\"Apartment, suite, etc. (optional)\" class=\"col-span-2 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            <input type=\"text\" placeholder=\"City\" class=\"col-span-1 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            <div class=\"col-span-1 flex gap-4\">\n              <select class=\"w-1/2 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none bg-white\">\n                <option>State</option>\n                <option>CA</option>\n                <option>NY</option>\n                <option>TX</option>\n              </select>\n              <input type=\"text\" placeholder=\"ZIP\" class=\"w-1/2 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n            </div>\n            <input type=\"tel\" placeholder=\"Phone\" class=\"col-span-2 border rounded-lg px-4 py-3 focus:ring-2 focus:ring-blue-600 focus:outline-none\" />\n          </div>\n        </section>\n\n        <!-- Payment Setup (Stripe Placeholder) -->\n        <section class=\"mb-10\">\n          <h2 class=\"text-xl font-bold mb-4\">Payment</h2>\n          <p class=\"text-sm text-gray-500 mb-4\">All transactions are secure and encrypted.</p>\n          <div class=\"border rounded-lg p-6 bg-gray-50 flex items-center justify-center h-48 border-dashed border-gray-300\">\n            <div class=\"text-center\">\n              <Icon name=\"lucide:credit-card\" class=\"w-12 h-12 text-gray-400 mx-auto mb-2\" />\n              <p class=\"text-gray-500 font-medium\">Stripe Payment Element will mount here</p>\n            </div>\n          </div>\n        </section>\n\n        <button class=\"w-full bg-blue-600 text-white rounded-lg py-4 font-bold text-lg hover:bg-blue-700 transition shadow-lg shadow-blue-600/20\">\n          Pay Now\n        </button>\n      </div>\n\n      <!-- Order Summary Sidebar -->\n      <div class=\"lg:w-1/3\">\n        <div class=\"bg-gray-50 rounded-2xl p-6 sticky top-24 border border-gray-100\">\n          <h2 class=\"text-xl font-bold mb-6\">Order Summary</h2>\n          \n          <div class=\"space-y-4 mb-6 max-h-[40vh] overflow-y-auto pr-2\">\n            <!-- Checkout Items -->\n            <div v-for=\"item in cartItems\" :key=\"item.id\" class=\"flex gap-4\">\n              <div class=\"relative\">\n                <div class=\"w-16 h-16 bg-white border rounded-lg flex-shrink-0\"></div>\n                <span class=\"absolute -top-2 -right-2 bg-gray-500 text-white text-xs w-5 h-5 flex items-center justify-center rounded-full\">{{ item.quantity }}</span>\n              </div>\n              <div class=\"flex-grow flex justify-between items-center\">\n                <div>\n                  <h4 class=\"font-medium text-sm\">{{ item.name }}</h4>\n                  <p class=\"text-xs text-gray-500\">{{ item.category }}</p>\n                </div>\n                <span class=\"font-medium text-sm\">${{ (item.price * item.quantity).toFixed(2) }}</span>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"border-y py-4 space-y-3 mb-4\">\n            <div class=\"flex justify-between text-sm\">\n              <span class=\"text-gray-600\">Subtotal</span>\n              <span class=\"font-medium\">${{ cartTotal.toFixed(2) }}</span>\n            </div>\n            <div class=\"flex justify-between text-sm\">\n              <span class=\"text-gray-600\">Shipping</span>\n              <span class=\"text-green-600 font-medium\">Free</span>\n            </div>\n            <div class=\"flex justify-between text-sm\">\n              <span class=\"text-gray-600\">Estimated Taxes</span>\n              <span class=\"font-medium\">${{ (cartTotal * 0.08).toFixed(2) }}</span>\n            </div>\n          </div>\n\n          <div class=\"flex justify-between items-end mb-6\">\n            <span class=\"text-lg font-bold\">Total</span>\n            <span class=\"text-2xl font-bold text-gray-900\">\n              <span class=\"text-sm font-normal text-gray-500 mr-1\">USD</span>${{ (cartTotal * 1.08).toFixed(2) }}\n            </span>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { computed } from 'vue'\nimport { useCartStore } from '~/stores/cart'\n\nconst cartStore = useCartStore()\n\n// If cart is empty, we fall back to some dummy data just to visualize the checkout page\nconst cartItems = computed(() => {\n  return cartStore.items.length > 0 ? cartStore.items : [\n    { id: 1, name: 'Premium Cotton T-Shirt', category: 'Men\\'s Clothing', price: 35.00, quantity: 2 },\n    { id: 4, name: 'Canvas Sneakers', category: 'Shoes', price: 45.00, quantity: 1 }\n  ]\n})\n\nconst cartTotal = computed(() => {\n  return cartItems.value.reduce((total, item) => total + (item.price * item.quantity), 0)\n})\n</script>\n"],"version":3}